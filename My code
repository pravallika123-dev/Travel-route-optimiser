#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <limits.h>
#include <time.h>

#define MAX_CITIES 15
#define INF        INT_MAX

typedef struct {
    char name[32];
    int  x, y;         
} City;

typedef struct {
    int  path[MAX_CITIES + 1];  
    int  path_len;
    long total_dist;
    char algo_name[32];
    double time_ms;
} Result;
static City cities[] = {
    {"Hyderabad",   0,   0},
    {"Vijayawada",  270, -80},
    {"Visakhapatnam", 580, 120},
    {"Tirupati",    -100, -320},
    {"Guntur",      250, -100},
    {"Nellore",     100, -280},
    {"Kurnool",     -80, -180},
    {"Kakinada",    450, 60},
};

static int  N = 8;   
static long dist[MAX_CITIES][MAX_CITIES];
static long euclidean(int i, int j) {
    long dx = cities[i].x - cities[j].x;
    long dy = cities[i].y - cities[j].y;
  
    long d2 = dx*dx + dy*dy;
    long r = (long)__builtin_sqrt((double)d2);
    return r;
}

static void build_distance_matrix(void) {
    for (int i = 0; i < N; i++)
        for (int j = 0; j < N; j++)
            dist[i][j] = (i == j) ? 0 : euclidean(i, j);
}

static void print_separator(char c, int n) {
    for (int i = 0; i < n; i++) putchar(c);
    putchar('\n');
}

static void print_result(const Result *r) {
    printf("\n  Algorithm : %s\n", r->algo_name);
    printf("  Route     : ");
    for (int i = 0; i <= r->path_len; i++) {
        printf("%s", cities[r->path[i]].name);
        if (i < r->path_len) printf(" → ");
    }
    printf("\n");
    printf("  Distance  : %ld km\n", r->total_dist);
    printf("  Time      : %.4f ms\n", r->time_ms);
}
Result greedy_tsp(int start) {
    Result res;
    strcpy(res.algo_name, "Greedy (Nearest Neighbour)");

    int visited[MAX_CITIES] = {0};
    res.path[0]   = start;
    res.path_len  = N;
    res.total_dist = 0;

    visited[start] = 1;
    int current    = start;

    clock_t t0 = clock();

    for (int step = 1; step < N; step++) {
        long best_d   = INF;
        int  best_city = -1;

        for (int j = 0; j < N; j++) {
            if (!visited[j] && dist[current][j] < best_d) {
                best_d    = dist[current][j];
                best_city = j;
            }
        }

        visited[best_city]  = 1;
        res.path[step]      = best_city;
        res.total_dist     += best_d;
        current             = best_city;
    }

   res.total_dist    += dist[current][start];
    res.path[N]        = start;

    clock_t t1  = clock();
    res.time_ms = (double)(t1 - t0) * 1000.0 / CLOCKS_PER_SEC;

    return res;
}
static long dp_table[1 << MAX_CITIES][MAX_CITIES];
static int  dp_parent[1 << MAX_CITIES][MAX_CITIES];

Result dp_tsp(int start) {
    Result res;
    strcpy(res.algo_name, "Dynamic Programming (Held-Karp)");

    int FULL = (1 << N) - 1;

    clock_t t0 = clock();

   
    for (int mask = 0; mask <= FULL; mask++)
        for (int i = 0; i < N; i++) {
            dp_table[mask][i]  = INF;
            dp_parent[mask][i] = -1;
        }

    dp_table[1 << start][start] = 0;

  
    for (int mask = 1; mask <= FULL; mask++) {
        for (int u = 0; u < N; u++) {
            if (!(mask & (1 << u)))          continue;
            if (dp_table[mask][u] == INF)    continue;

            for (int v = 0; v < N; v++) {
                if (mask & (1 << v))         continue;  

                int   new_mask = mask | (1 << v);
                long  new_cost = dp_table[mask][u] + dist[u][v];

                if (new_cost < dp_table[new_mask][v]) {
                    dp_table[new_mask][v]  = new_cost;
                    dp_parent[new_mask][v] = u;
                }
            }
        }
    }

  
    long best_d    = INF;
    int  last_city = -1;

    for (int u = 0; u < N; u++) {
        if (u == start) continue;
        if (dp_table[FULL][u] == INF) continue;
        long total = dp_table[FULL][u] + dist[u][start];
        if (total < best_d) {
            best_d    = total;
            last_city = u;
        }
    }

    res.total_dist = best_d;

    int path_rev[MAX_CITIES];
    int idx  = 0;
    int mask = FULL;
    int cur  = last_city;

    while (cur != -1) {
        path_rev[idx++] = cur;
        int prev = dp_parent[mask][cur];
        mask ^= (1 << cur);
        cur   = prev;
    }

   
    res.path_len = N;
    for (int i = 0; i < idx; i++)
        res.path[i] = path_rev[idx - 1 - i];
    res.path[N] = start;   

    clock_t t1  = clock();
    res.time_ms = (double)(t1 - t0) * 1000.0 / CLOCKS_PER_SEC;

    return res;
}



static void print_analysis(const Result *g, const Result *dp) {
    print_separator('=', 60);
    printf("  COMPARISON & ANALYSIS\n");
    print_separator('=', 60);

    long diff    = g->total_dist - dp->total_dist;
    double pct   = (dp->total_dist > 0)
                   ? (double)diff * 100.0 / dp->total_dist
                   : 0.0;

    printf("\n  %-30s  %8ld km\n", "Greedy distance:",       g->total_dist);
    printf("  %-30s  %8ld km\n", "DP (optimal) distance:", dp->total_dist);
    printf("  %-30s  %+8ld km  (%.2f%% worse)\n",
           "Greedy overhead:", diff, pct);

    printf("\n  %-30s  %8.4f ms\n", "Greedy time:",  g->time_ms);
    printf("  %-30s  %8.4f ms\n", "DP time:",       dp->time_ms);

    printf("\n");
    print_separator('-', 60);
    printf("  ALGORITHM INSIGHTS\n");
    print_separator('-', 60);
    printf("\n");
    printf("  Greedy:\n");
    printf("    + Extremely fast — O(N^2)\n");
    printf("    + Simple to implement\n");
    printf("    - Not always optimal (%.2f%% overhead here)\n", pct);
    printf("    - No backtracking; locks in early bad choices\n");
    printf("\n");
    printf("  Dynamic Programming (Held-Karp):\n");
    printf("    + Guaranteed optimal solution\n");
    printf("    + Explores ALL possible routes via bitmask\n");
    printf("    - Exponential time O(N^2 * 2^N) — slow for N>20\n");
    printf("    - High memory usage O(N * 2^N)\n");
    printf("\n");
    printf("  KEY TAKEAWAY:\n");
    printf("    Use Greedy for quick approximate answers on large\n");
    printf("    inputs. Use DP when exactness is required and N\n");
    printf("    is small (N <= 20).\n\n");
    print_separator('=', 60);
}

static void print_distance_matrix(void) {
    print_separator('-', 60);
    printf("  DISTANCE MATRIX (km)\n");
    print_separator('-', 60);

    /* header */
    printf("  %14s", "");
    for (int j = 0; j < N; j++)
        printf("  %6.6s", cities[j].name);
    printf("\n");

    for (int i = 0; i < N; i++) {
        printf("  %14.14s", cities[i].name);
        for (int j = 0; j < N; j++) {
            if (i == j) printf("  %6s", "—");
            else        printf("  %6ld", dist[i][j]);
        }
        printf("\n");
    }
    printf("\n");
}

int main(void) {
    build_distance_matrix();

    print_separator('=', 60);
    printf("   TRAVEL ROUTE OPTIMIZER  —  CCC Algorithm Project\n");
    printf("   Greedy vs Dynamic Programming (TSP)\n");
    print_separator('=', 60);

    printf("\n  Cities (%d):\n", N);
    for (int i = 0; i < N; i++)
        printf("    [%d] %s\n", i, cities[i].name);
    printf("\n");

    print_distance_matrix();

    int start = 0;  
    printf("  Starting city: %s\n\n", cities[start].name);

  
    print_separator('-', 60);
    printf("  RUNNING GREEDY ALGORITHM...\n");
    Result greedy = greedy_tsp(start);
    print_result(&greedy);

    print_separator('-', 60);
    printf("  RUNNING DP (HELD-KARP) ALGORITHM...\n");
    Result dp = dp_tsp(start);
    print_result(&dp);

    print_analysis(&greedy, &dp);

    return 0;
}
